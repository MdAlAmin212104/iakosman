{% comment %} {%- liquid
  assign section_id = section.id
  assign media_ratio = section.settings.media_ratio
-%}

{% style %}
  /* Section Scoping */
  .timeline-unique-{{ section_id }} {
    --bg-color: {{ section.settings.background_color | default: '#ffffff' }};
    --text-color: {{ section.settings.text_color | default: '#333' }};
    --heading-color: {{ section.settings.heading_color | default: '#000' }};
    --accent-color: {{ section.settings.line_and_border_color | default: '#e2e2e2' }};
    
    background-color: var(--bg-color);
    color: var(--text-color);
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  /* Layout */
  .timeline-grid-{{ section_id }} {
    display: flex;
    flex-direction: column;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .timeline-header-{{ section_id }} {
    text-align: {{ section.settings.heading_alignment }};
  }

  .timeline-header-{{ section_id }} h2 {
    color: var(--heading-color);
    font-size: calc(2rem * {{ section.settings.heading_size | divided_by: 100.0 }});
    margin-bottom: 10px;
  }

  /* Content Slider (Now Middle) */
  .timeline-content-pane {
    display: none;
    grid-template-columns: 1fr;
    gap: 30px;
    animation: fadeIn 0.5s ease forwards;
  }

  @media (min-width: 768px) {
    .timeline-content-pane {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
    .media-right { order: 2; }
  }

  .timeline-content-pane.active {
    display: grid;
  }

  .timeline-image-wrapper img, 
  .timeline-image-wrapper svg {
    width: 100%;
    height: auto;
    border-radius: 8px;
    aspect-ratio: {{ media_ratio | replace: '/', ' / ' }};
    object-fit: cover;
  }

  /* The Timeline Visual (Now Bottom) */
  .timeline-nav-wrapper {
    position: relative;
    padding: 20px 0;
    margin-top: 20px;
  }

  .timeline-line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent-color);
    z-index: 1;
  }

  .timeline-dots {
    display: flex;
    justify-content: space-between;
    position: relative;
    z-index: 2;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-dot-item {
    display: flex;
    flex-direction: column-reverse; /* Labels go above dots */
    align-items: center;
    cursor: pointer;
    flex: 1;
  }

  .dot-trigger {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg-color);
    border: 2px solid var(--accent-color);
    transition: all 0.3s ease;
    margin-top: 10px; /* Space between label and dot */
  }

  .dot-label {
    font-weight: bold;
    color: var(--text-color);
    transition: color 0.3s ease;
  }

  .timeline-dot-item.active .dot-trigger {
    background: var(--heading-color);
    border-color: var(--heading-color);
    transform: scale(1.3);
  }

  .timeline-dot-item.active .dot-label {
    color: var(--heading-color);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .btn-timeline {
    display: inline-block;
    padding: 12px 24px;
    text-decoration: none;
    border-radius: 4px;
    margin-top: 15px;
    background: var(--heading-color);
    color: var(--bg-color);
    transition: opacity 0.3s ease;
  }

  .btn-timeline:hover {
    opacity: 0.8;
  }
{% endstyle %}

<div class="timeline-unique-{{ section_id }}">
  <div class="timeline-grid-{{ section_id }}">
    
    <div class="timeline-header-{{ section_id }}">
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="timeline-main-content">
      {% for block in section.blocks %}
        <div id="TimelinePane-{{ section_id }}-{{ forloop.index0 }}" 
             class="timeline-content-pane {% if forloop.first %}active{% endif %}" 
             {{ block.shopify_attributes }}>
          
          <div class="timeline-text-col {% if section.settings.media_position == 'left' %}media-right{% endif %}">
            <h3 style="color: var(--heading-color);">{{ block.settings.heading }}</h3>
            <div class="rte">{{ block.settings.description }}</div>
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}" class="btn-timeline">{{ block.settings.button_label }}</a>
            {% endif %}
          </div>

          <div class="timeline-media-col">
            <div class="timeline-image-wrapper">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="timeline-nav-wrapper">
      <div class="timeline-line"></div>
      <div class="timeline-dots">
        {% for block in section.blocks %}
          <div class="timeline-dot-item {% if forloop.first %}active{% endif %}" 
               onclick="switchTimelineBlock('{{ section_id }}', {{ forloop.index0 }})"
               data-index="{{ forloop.index0 }}">
            <div class="dot-trigger"></div>
            <span class="dot-label">{{ block.settings.navigation_label }}</span>
          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</div>

<script>
  function switchTimelineBlock(sectionId, index) {
    const section = document.querySelector('.timeline-unique-' + sectionId);
    
    // Update active state on dots
    section.querySelectorAll('.timeline-dot-item').forEach(dot => dot.classList.remove('active'));
    section.querySelector(`[data-index="${index}"]`).classList.add('active');
    
    // Update active state on content panes
    section.querySelectorAll('.timeline-content-pane').forEach(pane => pane.classList.remove('active'));
    document.getElementById(`TimelinePane-${sectionId}-${index}`).classList.add('active');
  }
</script>

