<div class="header-social-icons d-flex align-items-center">
  {% if settings.social_facebook_link != blank %}
    <a class="hs-icon" href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
      {% render 'icon-facebook' %}
    </a>
  {% endif %}

  {% if settings.social_instagram_link != blank %}
    <a class="hs-icon" href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
      {% render 'icon-instagram' %}
    </a>
  {% endif %}

  {% if settings.social_twitter_link != blank %}
    <a class="hs-icon" href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" aria-label="X">
      {% render 'icon-twitter' %}
    </a>
  {% endif %}

  {% if settings.social_youtube_link != blank %}
    <a class="hs-icon" href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube">
      {% render 'icon-youtube' %}
    </a>
  {% endif %}
</div>
