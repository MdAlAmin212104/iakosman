{% doc %}
  @prompt
    Can you create a gallary section where if you click on it, it enlarges and shows you a small caption below it, need more images.. not just 9, I want to be able to on and off the images to reflect
    
    , image should be showing fully, But all image should be same size, In mobile device text should be more small
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gallery-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-gallery-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-gallery-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }

  .ai-gallery-item-{{ ai_gen_id }} {
    position: relative;
    cursor: pointer;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-gallery-item-{{ ai_gen_id }}:hover {
    transform: scale(1.02);
  }

  .ai-gallery-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-gallery-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-gallery-caption-preview-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    color: #ffffff;
    padding: 15px;
    font-size: 14px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-gallery-item-{{ ai_gen_id }}:hover .ai-gallery-caption-preview-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-gallery-modal-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.95);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-gallery-modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-gallery-modal-content-{{ ai_gen_id }} {
    position: relative;
    max-width: 90%;
    max-height: 90%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-gallery-modal-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 70vh;
    object-fit: contain;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-gallery-modal-caption-{{ ai_gen_id }} {
    background-color: {{ block.settings.caption_bg_color }};
    color: {{ block.settings.caption_text_color }};
    padding: 20px;
    margin-top: 15px;
    border-radius: 8px;
    max-width: 600px;
    text-align: center;
    font-size: 16px;
    line-height: 1.6;
  }

  .ai-gallery-modal-close-{{ ai_gen_id }} {
    position: absolute;
    top: -40px;
    right: 0;
    background: none;
    border: none;
    color: #ffffff;
    font-size: 36px;
    cursor: pointer;
    padding: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .ai-gallery-modal-close-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-gallery-modal-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: rgba(255, 255, 255, 0.2);
    border: none;
    color: #ffffff;
    font-size: 24px;
    cursor: pointer;
    padding: 15px 20px;
    border-radius: 4px;
    transition: background-color 0.3s ease;
  }

  .ai-gallery-modal-nav-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 0.3);
  }

  .ai-gallery-modal-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-gallery-modal-next-{{ ai_gen_id }} {
    right: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-gallery-caption-preview-{{ ai_gen_id }} {
      font-size: 11px;
      padding: 10px;
    }

    .ai-gallery-modal-caption-{{ ai_gen_id }} {
      font-size: 13px;
      padding: 15px;
      line-height: 1.5;
    }

    .ai-gallery-modal-nav-{{ ai_gen_id }} {
      padding: 10px 15px;
      font-size: 20px;
    }

    .ai-gallery-modal-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-gallery-modal-next-{{ ai_gen_id }} {
      right: 10px;
    }

    .ai-gallery-modal-close-{{ ai_gen_id }} {
      top: -35px;
      font-size: 30px;
    }
  }
{% endstyle %}

<gallery-lightbox-{{ ai_gen_id }}
  class="ai-gallery-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-gallery-grid-{{ ai_gen_id }}">
    {% for i in (1..20) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign caption_key = 'caption_' | append: i
        assign enabled_key = 'enable_image_' | append: i

        assign image = block.settings[image_key]
        assign caption = block.settings[caption_key]
        assign enabled = block.settings[enabled_key]
      %}

      {% if enabled %}
        <div
          class="ai-gallery-item-{{ ai_gen_id }}"
          data-gallery-index="{{ forloop.index0 }}"
        >
          <div class="ai-gallery-image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 600 }}"
                alt="{{ caption | escape }}"
                class="ai-gallery-image-{{ ai_gen_id }}"
                loading="lazy"
              >
            {% else %}
              <div class="ai-gallery-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if caption != blank %}
              <div class="ai-gallery-caption-preview-{{ ai_gen_id }}">
                {{ caption }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-gallery-modal-{{ ai_gen_id }}">
    <div class="ai-gallery-modal-content-{{ ai_gen_id }}">
      <button
        class="ai-gallery-modal-close-{{ ai_gen_id }}"
        aria-label="Close"
      >
        &times;
      </button>
      <img
        src=""
        alt=""
        class="ai-gallery-modal-image-{{ ai_gen_id }}"
      >
      <div class="ai-gallery-modal-caption-{{ ai_gen_id }}"></div>
    </div>
    <button
      class="ai-gallery-modal-nav-{{ ai_gen_id }} ai-gallery-modal-prev-{{ ai_gen_id }}"
      aria-label="Previous image"
    >
      &#8249;
    </button>
    <button
      class="ai-gallery-modal-nav-{{ ai_gen_id }} ai-gallery-modal-next-{{ ai_gen_id }}"
      aria-label="Next image"
    >
      &#8250;
    </button>
  </div>
</gallery-lightbox-{{ ai_gen_id }}>

<script>
  (function() {
    class GalleryLightbox{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.images = [];
      }

      connectedCallback() {
        this.modal = this.querySelector('.ai-gallery-modal-{{ ai_gen_id }}');
        this.modalImage = this.querySelector('.ai-gallery-modal-image-{{ ai_gen_id }}');
        this.modalCaption = this.querySelector('.ai-gallery-modal-caption-{{ ai_gen_id }}');
        this.closeBtn = this.querySelector('.ai-gallery-modal-close-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-gallery-modal-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-gallery-modal-next-{{ ai_gen_id }}');

        this.collectImages();
        this.setupEventListeners();
      }

      collectImages() {
        const items = this.querySelectorAll('.ai-gallery-item-{{ ai_gen_id }}');
        this.images = Array.from(items).map(item => {
          const img = item.querySelector('.ai-gallery-image-{{ ai_gen_id }}');
          const caption = item.querySelector('.ai-gallery-caption-preview-{{ ai_gen_id }}');
          
          if (img) {
            return {
              src: img.src,
              alt: img.alt,
              caption: caption ? caption.textContent : ''
            };
          }
          return null;
        }).filter(item => item !== null);
      }

      setupEventListeners() {
        const items = this.querySelectorAll('.ai-gallery-item-{{ ai_gen_id }}');
        
        items.forEach((item, index) => {
          const img = item.querySelector('.ai-gallery-image-{{ ai_gen_id }}');
          if (img) {
            item.addEventListener('click', () => {
              this.openModal(index);
            });
          }
        });

        this.closeBtn.addEventListener('click', () => {
          this.closeModal();
        });

        this.prevBtn.addEventListener('click', () => {
          this.navigate(-1);
        });

        this.nextBtn.addEventListener('click', () => {
          this.navigate(1);
        });

        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) {
            this.closeModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (!this.modal.classList.contains('active')) return;
          
          if (e.key === 'Escape') {
            this.closeModal();
          } else if (e.key === 'ArrowLeft') {
            this.navigate(-1);
          } else if (e.key === 'ArrowRight') {
            this.navigate(1);
          }
        });
      }

      openModal(index) {
        if (this.images.length === 0) return;
        
        this.currentIndex = index;
        this.updateModalContent();
        this.modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closeModal() {
        this.modal.classList.remove('active');
        document.body.style.overflow = '';
      }

      navigate(direction) {
        this.currentIndex = (this.currentIndex + direction + this.images.length) % this.images.length;
        this.updateModalContent();
      }

      updateModalContent() {
        const image = this.images[this.currentIndex];
        if (!image) return;

        this.modalImage.src = image.src;
        this.modalImage.alt = image.alt;
        
        if (image.caption) {
          this.modalCaption.textContent = image.caption;
          this.modalCaption.style.display = 'block';
        } else {
          this.modalCaption.style.display = 'none';
        }
      }
    }

    customElements.define('gallery-lightbox-{{ ai_gen_id }}', GalleryLightbox{{ ai_gen_id }});
  })();
</script>

